# Auto detect text files and normalize line endings
* text=auto

# Shell scripts must use LF (for husky hooks on CI)
*.sh text eol=lf
.husky/* text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
